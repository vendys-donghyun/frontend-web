{
  "name": "@vendys/tokens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./css": "./dist/tokens.css"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean && cp src/tokens.css dist/",
    "dev": "tsup src/index.ts --format esm,cjs --watch",
    "lint": "eslint ."
  },
  "devDependencies": {
    "tsup": "catalog:",
    "typescript": "catalog:",
    "eslint": "^9.0.0",
    "@vendys/eslint-config": "workspace:*",
    "@vendys/typescript-config": "workspace:*"
  }
}
